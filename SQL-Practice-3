---- Nested Case 
select 
      pr.Promotion_ID,
      pr.Promotion_Name,
      s.unit_sold,
      case
           when pr.Promotion_Name = 'Summer sale' then
               case when s.Unit_Sold>5 then 'Premium Summer sale' else 'Affordable Summer sale'
               end
       
          when pr.Promotion_Name = 'Festive Diwali' then
              case when s.Unit_Sold >5 then 'Premium Festive Diwali' else 'Affordable Festive Diwali'
              end
       
          when pr.Promotion_Name = 'New Year Special' then 
              case when s.Unit_Sold >5 then 'Premium New Year Special' else 'Affordable New Year Special'
              end
          when pr.Promotion_Name = 'Weekend Flash Sale' then 
              case when s.Unit_Sold >5 then 'Premium Weekend Flash Sale' else 'Affordable Weekend Flash Sale'
              end 
 else
              case when s.Unit_Sold >5 then 'Premium Clearance Sale' else 'Affordable Clearance Sale' 
              end
      end as [Promotion Category]
from Sales_Table s join Promotion_Table pr on s.Promotion_ID=pr.Promotion_ID

