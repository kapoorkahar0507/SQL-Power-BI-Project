where price>3000
group by product_line 
having sum(price) > 10000

select distinct product_line from Product_Table

select * from Product_Table
order by
      case 
          when product_line in ('Electronics') then 1
          when product_line in ('Accessories') then 2
          when product_line in ('Clothing') then 3
          when product_line in ('Footwear') then 4
          when product_line in ('Furniture') then 5
          when product_line in ('Home Appliances') then 6
          when product_line in ('Home Decor') then 7
          when product_line in ('Kitchen') then 8
          else 9
end 
